					valign top_ref
					text "ATUALIZAR"
				}

				ButtonWidgetClass RestoreButton
				{
					ignorepointer 0
					visible 1
					position 0.36 0.82
					size 0.28 0.08
					halign left_ref
					valign top_ref
					text "RESTAURAR"
				}

				ButtonWidgetClass CloseButton
				{
					ignorepointer 0
					visible 1
					position 0.67 0.82
					size 0.28 0.08
					halign left_ref
					valign top_ref
					text "FECHAR"
				}
			}
		}
	}
}